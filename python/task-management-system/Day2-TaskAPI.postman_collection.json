{
  "info": {
    "name": "Day2-TaskAPI",
    "description": "Complete Postman collection for the FastAPI Task Management System.\n\nBase URL: http://localhost:8000\n\nFolders:\n- Users: Register, Login, List, Delete\n- Tasks: Create, List (with filters), Get by ID, PUT, PATCH, Delete\n- Error Cases: Validation, Not Found, Duplicate, Bad Credentials",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Register User (201)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice@mail.com\",\n  \"password\": \"securepass123\"\n}"
            },
            "url": { "raw": "{{base_url}}/users/register", "host": ["{{base_url}}"], "path": ["users", "register"] },
            "description": "Register a new user. Expected: 201 Created.\nReturns id, username, email, created_at. Password is NOT in the response."
          }
        },
        {
          "name": "Login User (200)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"securepass123\"\n}"
            },
            "url": { "raw": "{{base_url}}/users/login", "host": ["{{base_url}}"], "path": ["users", "login"] },
            "description": "Login with valid credentials. Expected: 200 OK."
          }
        },
        {
          "name": "List All Users (200)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/users", "host": ["{{base_url}}"], "path": ["users"] },
            "description": "Get all registered users. Expected: 200 OK. Passwords excluded."
          }
        },
        {
          "name": "Delete User (200)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/users/1", "host": ["{{base_url}}"], "path": ["users", "1"] },
            "description": "Delete user with id=1. Expected: 200 OK."
          }
        }
      ]
    },
    { 
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task (201)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Write Q2 report\",\n  \"description\": \"Summarize Q2 performance metrics\",\n  \"priority\": \"high\",\n  \"owner\": \"alice\"\n}"
            },
            "url": { "raw": "{{base_url}}/tasks", "host": ["{{base_url}}"], "path": ["tasks"] },
            "description": "Create a new task. Owner must be a registered username. Expected: 201 Created."
          }
        },
        {
          "name": "List All Tasks (200)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/tasks", "host": ["{{base_url}}"], "path": ["tasks"] },
            "description": "List all tasks with default pagination (page=1, limit=10). Expected: 200 OK."
          }
        },
        {
          "name": "Filter by Status (200)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tasks?status=pending",
              "host": ["{{base_url}}"],
              "path": ["tasks"],
              "query": [{ "key": "status", "value": "pending" }]
            },
            "description": "Filter tasks by status=pending. Expected: 200 OK, only pending tasks."
          }
        },
        {
          "name": "Filter by Priority (200)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tasks?priority=high",
              "host": ["{{base_url}}"],
              "path": ["tasks"],
              "query": [{ "key": "priority", "value": "high" }]
            },
            "description": "Filter tasks by priority=high. Expected: 200 OK."
          }
        },
        {
          "name": "Filter by Owner (200)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tasks?owner=alice",
              "host": ["{{base_url}}"],
              "path": ["tasks"],
              "query": [{ "key": "owner", "value": "alice" }]
            },
            "description": "Filter tasks by owner=alice. Expected: 200 OK, only alice's tasks."
          }
        },
        {
          "name": "Filter Combined + Paginated (200)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tasks?priority=high&owner=alice&page=1&limit=5",
              "host": ["{{base_url}}"],
              "path": ["tasks"],
              "query": [
                { "key": "priority", "value": "high" },
                { "key": "owner", "value": "alice" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "5" }
              ]
            },
            "description": "Combine multiple filters with pagination. Expected: 200 OK."
          }
        },
        {
          "name": "Get Task by ID (200)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/tasks/1", "host": ["{{base_url}}"], "path": ["tasks", "1"] },
            "description": "Fetch task with id=1. Expected: 200 OK with full task data."
          }
        },
        {
          "name": "Full Update Task - PUT (200)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated report title\",\n  \"description\": \"Revised description\",\n  \"priority\": \"medium\",\n  \"status\": \"in_progress\",\n  \"owner\": \"alice\"\n}"
            },
            "url": { "raw": "{{base_url}}/tasks/1", "host": ["{{base_url}}"], "path": ["tasks", "1"] },
            "description": "Full update — ALL fields required. Expected: 200 OK. updated_at will refresh."
          }
        },
        {
          "name": "Partial Update Task - PATCH (200)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}"
            },
            "url": { "raw": "{{base_url}}/tasks/1", "host": ["{{base_url}}"], "path": ["tasks", "1"] },
            "description": "Partial update — only send fields to change. Expected: 200 OK. Other fields unchanged."
          }
        },
        {
          "name": "Delete Task (200)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/tasks/1", "host": ["{{base_url}}"], "path": ["tasks", "1"] },
            "description": "Delete task with id=1. Expected: 200 OK with success message."
          }
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Invalid Payload - Missing required field (422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"No priority or owner\"\n}"
            },
            "url": { "raw": "{{base_url}}/tasks", "host": ["{{base_url}}"], "path": ["tasks"] },
            "description": "Missing 'owner' field. Expected: 422 Unprocessable Entity with ValidationError."
          }
        },
        {
          "name": "Invalid Enum Value (422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test task\",\n  \"priority\": \"urgent\",\n  \"owner\": \"alice\"\n}"
            },
            "url": { "raw": "{{base_url}}/tasks", "host": ["{{base_url}}"], "path": ["tasks"] },
            "description": "'urgent' is not a valid TaskPriority value. Expected: 422 with ValidationError."
          }
        },
        {
          "name": "Task Not Found (404)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/tasks/9999", "host": ["{{base_url}}"], "path": ["tasks", "9999"] },
            "description": "Task id=9999 doesn't exist. Expected: 404 with TaskNotFoundError."
          }
        },
        {
          "name": "User Not Found - Delete (404)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/users/9999", "host": ["{{base_url}}"], "path": ["users", "9999"] },
            "description": "User id=9999 doesn't exist. Expected: 404 with UserNotFoundError."
          }
        },
        {
          "name": "Duplicate Username (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice2@mail.com\",\n  \"password\": \"anotherpass123\"\n}"
            },
            "url": { "raw": "{{base_url}}/users/register", "host": ["{{base_url}}"], "path": ["users", "register"] },
            "description": "Register with existing username 'alice'. Expected: 409 Conflict with DuplicateUserError."
          }
        },
        {
          "name": "Bad Credentials (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": { "raw": "{{base_url}}/users/login", "host": ["{{base_url}}"], "path": ["users", "login"] },
            "description": "Login with wrong password. Expected: 401 Unauthorized with InvalidCredentialsError."
          }
        },
        {
          "name": "Create Task - Invalid Owner (404)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Orphan task\",\n  \"priority\": \"low\",\n  \"owner\": \"nonexistentuser\"\n}"
            },
            "url": { "raw": "{{base_url}}/tasks", "host": ["{{base_url}}"], "path": ["tasks"] },
            "description": "Task owner doesn't exist. Expected: 404 with UserNotFoundError."
          }
        },
        {
          "name": "Pagination Beyond Data (200 empty)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tasks?page=999&limit=10",
              "host": ["{{base_url}}"],
              "path": ["tasks"],
              "query": [
                { "key": "page", "value": "999" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Page far beyond available data. Expected: 200 OK with empty array [] (NOT an error)."
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check (200)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] },
            "description": "App health check. Expected: 200 OK with status=ok."
          }
        }
      ]
    }
  ]
}
